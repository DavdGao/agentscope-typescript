{
    "compilerOptions": {
        "target": "es2022",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "declaration": true
    },
    "include": ["src/**/*", "tsup.config.ts"],
    "exclude": ["node_modules", "dist"]
}
